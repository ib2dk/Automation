    {
      "parameters": {
        "sendTo": "support@yourcompany.com",
        "subject": "=Urgent Customer Complaint - {{ $json.Order_id }}",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background-color:#f0f7f4;font-family:Arial,sans-serif;\">\n  <div style=\"max-width:600px;margin:0 auto;background:#ffffff;border-radius:12px;overflow:hidden;margin-top:20px;\">\n    \n    <!-- Header -->\n    <div style=\"background-color:#2d7a5f;padding:30px;text-align:center;\">\n      <h1 style=\"color:#ffffff;margin:0;font-size:22px;letter-spacing:1px;\">\ud83d\udea8 Urgent Support Alert</h1>\n      <p style=\"color:#a8d5c2;margin:6px 0 0;\">Tobio's Customer Support System</p>\n    </div>\n\n    <!-- Body -->\n    <div style=\"padding:30px;\">\n      <p style=\"color:#333;font-size:15px;\">A high-urgency customer complaint has been detected and requires <strong>immediate attention.</strong></p>\n\n      <!-- Details Card -->\n      <div style=\"background:#f0f7f4;border-left:4px solid #2d7a5f;border-radius:8px;padding:20px;margin:20px 0;\">\n        <table style=\"width:100%;border-collapse:collapse;\">\n          <tr>\n            <td style=\"padding:8px 0;color:#777;font-size:13px;width:40%;\">Order ID</td>\n            <td style=\"padding:8px 0;color:#222;font-weight:bold;\">{{ $json.Order_id }}</td>\n          </tr>\n          <tr>\n            <td style=\"padding:8px 0;color:#777;font-size:13px;\">Category</td>\n            <td style=\"padding:8px 0;color:#222;font-weight:bold;\">{{ $json.Category }}</td>\n          </tr>\n          <tr>\n            <td style=\"padding:8px 0;color:#777;font-size:13px;\">Sentiment</td>\n            <td style=\"padding:8px 0;color:#c0392b;font-weight:bold;\">\ud83d\ude20 {{ $json.Sentiment }}</td>\n          </tr>\n          <tr>\n            <td style=\"padding:8px 0;color:#777;font-size:13px;\">Urgency</td>\n            <td style=\"padding:8px 0;color:#e67e22;font-weight:bold;\">\u26a0\ufe0f {{ $json.Urgency }}</td>\n          </tr>\n          <tr>\n            <td style=\"padding:8px 0;color:#777;font-size:13px;\">AI Confidence</td>\n            <td style=\"padding:8px 0;color:#222;font-weight:bold;\">{{ $json.Confidence }}</td>\n          </tr>\n          <tr>\n            <td style=\"padding:8px 0;color:#777;font-size:13px;\">Timestamp</td>\n            <td style=\"padding:8px 0;color:#222;\">{{ $json.Timestamp }}</td>\n          </tr>\n        </table>\n      </div>\n\n      <p style=\"color:#333;font-size:14px;\">Please follow up with this customer as soon as possible to resolve their issue.</p>\n\n    <!-- Footer -->\n    <div style=\"background:#f0f7f4;padding:20px;text-align:center;\">\n      <p style=\"color:#999;font-size:12px;margin:0;\">This is an automated alert from Tobio's AI Support Pipeline</p>\n      <p style=\"color:#999;font-size:12px;margin:4px 0 0;\">\u00a9 2026 Tobio's \u00b7 All rights reserved</p>\n    </div>\n\n  </div>\n</body>\n</html>",
        "options": {
          "appendAttribution": false
        }
      },
